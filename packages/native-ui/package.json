{
  "name": "@init/native-ui",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "exports": {
    "./blocks/*": "./src/blocks/*.tsx",
    "./components/*": "./src/components/*.tsx",
    "./globals.css": "./src/styles/globals.css",
    "./hooks/*": "./src/hooks/*.ts",
    "./icons/*": "./src/icons/*.ts",
    "./tailwind.config": "./tailwind.config.ts",
    "./theme": "./src/theme/index.ts"
  },
  "scripts": {
    "check": "biome check --write .",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "components:add": "pnpx @react-native-reusables/cli add",
    "components:diff": "pnpx @react-native-reusables/cli diff",
    "format": "biome format --write .",
    "lint": "biome lint --fix .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@init/utils": "workspace:*",
    "@react-navigation/native": "7.1.9",
    "@rn-primitives/avatar": "1.1.0",
    "@rn-primitives/hooks": "^1.2.0",
    "@rn-primitives/slot": "1.1.0",
    "@rn-primitives/tabs": "^1.1.0",
    "@rn-primitives/toggle": "^1.1.0",
    "@rn-primitives/toggle-group": "^1.1.0",
    "@rn-primitives/tooltip": "^1.1.0",
    "@roninoss/icons": "0.0.4",
    "@tanstack/react-form": "1.11.1",
    "class-variance-authority": "0.7.1",
    "expo-navigation-bar": "^4.2.4",
    "lucide-react-native": "0.475.0",
    "react-native": "0.79.2",
    "react-native-reanimated": "3.17.5"
  },
  "devDependencies": {
    "@react-native-reusables/cli": "^0.3.8",
    "@tooling/tsconfig": "workspace:*",
    "@types/react": "19.1.4",
    "@types/react-dom": "19.1.5",
    "tailwindcss-animate": "1.0.7",
    "typescript": "5.8.3"
  },
  "peerDependencies": {
    "nativewind": ">=4.1.23",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "react-native": ">=0.79.0",
    "tailwindcss": ">=3.4.0"
  }
}
