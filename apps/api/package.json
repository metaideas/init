{
  "name": "api",
  "exports": {
    "./client": {
      "import": {
        "types": "./dist/client.d.ts"
      }
    }
  },
  "scripts": {
    "check": "biome check --write .",
    "clean": "git clean -xdf .cache .turbo .wrangler dist node_modules",
    "deploy": "wrangler deploy --minify --env production",
    "deploy:dry-run": "wrangler deploy --dry-run --outdir ./dist",
    "dev": "wrangler dev --port 3001 --env development",
    "format": "biome format --write .",
    "lint": "biome lint --fix .",
    "postinstall": "bun run typegen:cloudflare && bun run typegen:client",
    "typecheck": "tsc --noEmit",
    "typegen:client": "tsup src/client.ts --dts-only",
    "typegen:client:watch": "bun run typegen:client --watch",
    "typegen:cloudflare": "wrangler types"
  },
  "dependencies": {
    "@hono/trpc-server": "0.3.4",
    "@hono/zod-validator": "0.4.3",
    "@this/auth": "workspace:*",
    "@this/db": "workspace:*",
    "@this/env": "workspace:*",
    "@this/observability": "workspace:*",
    "@this/utils": "workspace:*",
    "@trpc/server": "11.0.0-rc.828",
    "hono": "4.7.4",
    "pino": "9.6.0"
  },
  "devDependencies": {
    "@tooling/tsconfig": "workspace:*",
    "@types/node": "22.13.10",
    "typescript": "5.8.2",
    "wrangler": "4.0.0"
  }
}
