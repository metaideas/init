    "@this/observability": "workspace:*",
    "@this/utils": "workspace:*",
    "fumadocs-core": "15.0.17",
    "fumadocs-mdx": "11.5.6",
    "fumadocs-ui": "15.0.17",
    "next": "15.2.2",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@fumadocs/cli": "0.0.8",
    "@tailwindcss/postcss": "4.0.14",
    "@tooling/tsconfig": "workspace:*",
    "@types/mdx": "2.0.13",
    "@types/node": "22.13.10",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "postcss": "8.5.3",
