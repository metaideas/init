{
  "name": "docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "analyze": "ANALYZE=true next build",
    "build": "next build",
    "check": "biome check --write .",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "next dev --port 3005",
